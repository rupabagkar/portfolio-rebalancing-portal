{
  "name": "portfolio-rebalancing-platform-backend",
  "version": "1.0.0",
  "description": "Backend API server for portfolio-rebalancing-platform-frontend",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "db:migrate": "psql $DATABASE_URL -f database/migrations/*.sql",
    "db:seed": "psql $DATABASE_URL -f database/seeds/seed.sql",
    "db:reset": "npm run db:migrate && npm run db:seed",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "test": "node --test tests/**/*.test.js",
    "lint": "eslint src/"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "morgan": "^1.10.0",
    "winston": "^3.11.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "swagger-ui-express": "^5.0.0",
    "pg": "^8.11.3",
    "@prisma/client": "^5.7.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "eslint": "^8.54.0",
    "prisma": "^5.7.0"
  },
  "keywords": [
    "api",
    "backend",
    "express",
    "rest"
  ],
  "author": "",
  "license": "MIT"
}